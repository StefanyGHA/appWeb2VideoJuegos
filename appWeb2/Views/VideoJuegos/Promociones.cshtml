@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Promociones";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">Promociones</h2>

    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100 position-relative">

                    <div class="badge-top">+@juego.EdadPermitida</div>

                    <div class="badge bg-danger position-absolute m-2" style="right: 10px; top: 10px;">
                        Oferta
                    </div>

                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <img src="@juego.imagen" class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@juego.titulo</h5>

                        @if (juego.PrecioAnterior.HasValue)
                        {
                            <p class="mb-1 text-muted">
                                <del>$@juego.PrecioAnterior</del>
                            </p>
                        }

                        <h4 class="price mt-2 text-danger">$@juego.precio</h4>

                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.idcategoria</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>