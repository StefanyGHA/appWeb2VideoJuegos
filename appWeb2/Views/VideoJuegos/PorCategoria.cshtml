@using Microsoft.AspNetCore.Http

@{
    var usuario = Context.Session.GetString("usuario");
}
@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Juegos por categoría";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">
        Categoría: @ViewBag.Categoria
    </h2>

    <div class="text-center mb-4">
        <a asp-action="Categorias" class="btn btn-secondary">Volver a categorías</a>
    </div>

    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100 position-relative">

                    <div class="badge-top">+@juego.EdadPermitida</div>

                    @if (juego.TienePromocion)
                    {
                        <div class="badge bg-danger position-absolute m-2" style="right: 10px; top: 10px;">
                            Oferta
                        </div>
                    }

                    <img src="@juego.imagen" class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@juego.titulo</h5>

                        @if (juego.PrecioAnterior.HasValue)
                        {
                            <p class="mb-1 text-muted">
                                <del>$@juego.PrecioAnterior</del>
                            </p>
                        }

                        <h4 class="price mt-2">$@juego.precio</h4>
                        @if (!string.IsNullOrEmpty(usuario))
                        {
                            <div id="paypal-button-@juego.Id" class="mt-3"></div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-warning mt-3">
                                Inicia sesión para comprar
                            </a>
                        }

                        <div class="mb-2">
                            @if (juego.EdadPermitida <= 12)
                            {
                                <span class="badge bg-success">Niños</span>
                            }
                            else if (juego.EdadPermitida >= 13 && juego.EdadPermitida <= 17)
                            {
                                <span class="badge bg-warning text-dark">Adolescentes</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Adultos</span>
                            }
                        </div>

                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.Categoria?.categoria</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@if (!string.IsNullOrEmpty(usuario))
{
    <script src="https://www.paypal.com/sdk/js?client-id=ASRsvCdHo6DNCms8C7aQtkBX482MglOrrjXBQOjH6Nlp6ukvJ4MVAWW6QNaxPo1j7fjovikerMO_9_O5&currency=USD"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        @foreach (var item in Model)
        {
            <text>
                paypal.Buttons({
                createOrder: async function () {
                const response = await fetch('/PayPal/CreateOrder', {
                method: 'POST',
                headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'amount=@item.precio'
                });

                const data = await response.json();
                return data.id;
                },

                onApprove: async function (data) {
                const response = await fetch('/PayPal/CaptureOrder', {
                method: 'POST',
                headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'orderId=' + data.orderID + '&videojuegoId=@item.Id&cantidad=1&total=@item.precio'
                });

                const result = await response.text();
                console.log(result);
                alert('Pago completado: @item.titulo');
                },

                onError: function (err) {
                console.error(err);
                alert('Error con PayPal');
                }
                }).render('#paypal-button-@item.Id');
            </text>
        }
        });
    </script>
}