@model IEnumerable<appWeb2.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-5" style="color: #FFD700;">Categorías</h2>

    <div class="row g-4">
        @foreach (var categoria in Model)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-action="PorCategoria" asp-route-id="@categoria.idcategoria" class="text-decoration-none">
                    <div class="card shadow-sm text-center p-4 h-100 category-card">
                        <i class="fa-solid fa-gamepad fa-2x text-warning mb-3"></i>
                        <h5 class="fw-bold text-dark">@categoria.categoria</h5>
                        <p class="text-muted mb-0">Ver juegos de esta categoría</p>
                    </div>
                </a>
            </div>
        }
    </div>
</div>