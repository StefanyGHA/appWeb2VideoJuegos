@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Categorías";
    var categorias = Model.GroupBy(v => v.categoria);
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">Categorías</h2>

    @foreach (var grupo in categorias)
    {
        <div class="mb-5">
            <h3 class="mb-3 text-warning">@grupo.Key</h3>

            <div class="row g-4">
                @foreach (var juego in grupo)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card game-card h-100 position-relative">

                            <div class="badge-top">+@juego.EdadPermitida</div>

                            <img src="@juego.imagen" class="card-img-top game-img" />

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold">@juego.titulo</h5>
                                <h4 class="price mt-2">$@juego.precio</h4>

                                <div class="mb-2">
                                    @{
                                        string categoriaEdad = "";

                                        if (juego.EdadPermitida <= 12)
                                            categoriaEdad = "Niños";
                                        else if (juego.EdadPermitida <= 17)
                                            categoriaEdad = "Adolescentes";
                                        else
                                            categoriaEdad = "Adultos";
                                    }

                                    <span class="badge bg-info">@categoriaEdad</span>
                                </div>

                                <div class="d-flex align-items-center mt-auto">
                                    <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                                    <span class="text-muted">@juego.categoria</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>