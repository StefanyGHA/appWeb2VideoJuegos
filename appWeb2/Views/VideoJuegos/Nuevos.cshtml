@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Nuevos Juegos";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">Nuevos Juegos</h2>

    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100 position-relative">

                    <div class="badge-top">+@juego.EdadPermitida</div>

                    <div class="badge bg-success position-absolute m-2" style="right: 10px; top: 10px;">
                        Nuevo
                    </div>

                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <img src="@juego.imagen" class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@juego.titulo</h5>

                        <h4 class="price mt-2">$@juego.precio</h4>

                        <div class="d-flex align-items-center mt-auto mb-2">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.categoria</span>
                        </div>

                        <small class="text-muted">
                            Agregado: @juego.FechaRegistro.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>