@{
    Layout = null;
    var usurio = Context.Session.GetString("usuario");
}
@model List<VentaViewModel>
<form method="get">
    <input type="date" name="desde" value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" />
    <input type="date" name="hasta" value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" />
    <button type="submit">Filtrar</button>
</form>

<table>
    <thead>
    <tr>
        <td>Usuario</td>
        <td>VideoJuego</td>
        <td>Cantidad</td>
        <td>Total</td>
        <td>Estado</td>
        <td>Fecha</td>
        <td>Codigo</td>
    </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
            <td>@item.UsuarioId</td>
            <td>@item.VideoJuegosId</td>
            <td>@item.cantidad</td>
            <td>@item.total</td>
            <td>@item.estadoCompra</td>
            <td>@item.fechaHoraTransacion</td>
            <td>@item.codigoTransaccion</td>
            </tr>
        }
    </tbody>
</table>

<div>
    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
    {
        <a href="?pagina=@i&desde=@ViewBag.Desde&hasta=@ViewBag.Hasta">
            @i
        </a>
    }
</div>
