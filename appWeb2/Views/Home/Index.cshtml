@model IEnumerable<appWeb2.Models.VideoJuegos>
@{
    ViewData["Title"] = "Videojuegos";
}

<div class="container mt-5">
    <div class="row text-center mb-5">

        <!-- CATEGORÍAS -->
        <div class="col-md-3 mb-3">
            <a asp-controller="VideoJuegos" asp-action="Categorias" class="text-decoration-none">
                <div class="feature-card">
                    <i class="fas fa-gamepad"></i>
                    <h5>Categorías</h5>
                    <p>Explora por tipo de juego</p>
                </div>
            </a>
        </div>

        <!-- MÁS VENDIDOS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-fire"></i>
                <h5>Más Vendidos</h5>
                <p>Los juegos más populares</p>
            </div>
        </div>

        <!-- NUEVOS -->
        <div class="col-md-3 mb-3">
            <a asp-controller="VideoJuegos" asp-action="Nuevos" class="text-decoration-none">
                <div class="feature-card">
                    <i class="fas fa-star"></i>
                    <h5>Nuevos Juegos</h5>
                    <p>Lo último en la tienda</p>
                </div>
            </a>
        </div>

        <!-- PROMOCIONES -->
        <div class="col-md-3 mb-3">
       <a asp-controller="VideoJuegos" asp-action="Promociones" class="text-decoration-none">
            <div class="feature-card">
                <i class="fas fa-tags"></i>
                <h5>Promociones</h5>
                <p>Ofertas especiales</p>
            </div>
       </a>
        </div>

    </div>


    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;"> Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- 🔴 BADGE SUPERIOR -->
                    <div class="badge-top">+@juego.EdadPermitida</div>

                    <!-- ❤️ FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.titulo
                        </h5>


                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.precio
                        </h4>

                        <!-- BOTÓN COMPRAR -->
                        <div id="paypal-button-@juego.Id" class="mt-3"></div>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.idcategoria</span>
                        </div>

                    </div>
                </div>
            </div>
           
        }
    </div>
    <script src="https://www.paypal.com/sdk/js?client-id=ASRsvCdHo6DNCms8C7aQtkBX482MglOrrjXBQOjH6Nlp6ukvJ4MVAWW6QNaxPo1j7fjovikerMO_9_O5&currency=USD"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        @foreach (var item in Model)
        {
            <text>
                paypal.Buttons({
                createOrder: async function () {
                const response = await fetch('/PayPal/CreateOrder', {
                method: 'POST',
                headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'amount=@item.precio'
                });

                const data = await response.json();
                return data.id;
                },

                onApprove: async function (data) {
                const response = await fetch('/PayPal/CaptureOrder', {
                method: 'POST',
                headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'orderId=' + data.orderID
                });

                const result = await response.text();
                console.log(result);
                alert('Pago completado: @item.titulo');
                },

                onError: function (err) {
                console.error(err);
                alert('Error con PayPal');
                }
                }).render('#paypal-button-@item.Id');
            </text>
        }
        });
    </script>